    {
      "parameters": {
        "jsCode": "const cleaned = [];\n\nfor (const item of $input.all()) {\n  const row = item.json;\n\n  // Skip header rows and empty rows\n  if (!row.PlatformID || row.PlatformID === 'PlatformID') continue;\n\n  // Skip flagged data quality rows\n  if (row.Data_Quality === 'FLAG') continue;\n\n  cleaned.push({\n    json: {\n      platform_id:    String(row.PlatformID || '').trim(),\n      region:         String(row.Region || '').trim(),\n      year:           parseInt(row.Year) || null,\n      quarter:        parseInt(row.Quater) || null,\n      subscribers_m:  parseFloat(row.Subscribers_M) || null,\n      source:         String(row.Source || 'Manual').trim()\n    }\n  });\n}\n\nreturn cleaned;"
      },
